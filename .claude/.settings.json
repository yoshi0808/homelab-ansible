{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(ansible-playbook * --syntax-check*)",
      "Bash(ansible-playbook * --check*)",
      "Bash(ansible-lint*)",
      "Bash(yamllint*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git branch*)",
      "Bash(git show*)",

      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(tree*)",
      "Bash(file*)",
      "Bash(pwd)",

      "Bash(mkdir*)",
      "Bash(touch*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(sed*)",

      "Read",

      "Bash(bash -n *)",
      "Bash(jq *)"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(ssh*)"
    ]
  }
}
