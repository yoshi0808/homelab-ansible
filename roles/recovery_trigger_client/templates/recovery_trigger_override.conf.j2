# Drop-in override: add OnFailure= to existing service unit.
# File: /etc/systemd/system/{{ item }}.d/recovery-trigger.conf
#
# OnFailure= fires after the unit enters the "failed" state,
# i.e. after systemd exhausts all Restart= attempts.
# We do not override Restart= or StartLimitBurst= here — those keep
# their existing values so systemd's built-in retry runs first.

[Unit]
OnFailure=recovery-notify-quory@%n.service
