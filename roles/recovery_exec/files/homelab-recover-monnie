#!/bin/bash
# homelab-recover-monnie: restart all monitoring services on monnie (no arguments).
# Hostname and action are hardcoded (§4.3: fixed forced command, no params).
set -euo pipefail

KEY=/home/recovery-exec/.ssh/id_recovery_action
KNOWN=/home/recovery-exec/.ssh/known_hosts

exec ssh -T \
    -i "$KEY" \
    -o StrictHostKeyChecking=yes \
    -o UserKnownHostsFile="$KNOWN" \
    -o ConnectTimeout=15 \
    -o BatchMode=yes \
    "recovery-exec@monnie.internal"
