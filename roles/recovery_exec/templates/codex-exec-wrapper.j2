#!/bin/bash
# codex-exec-wrapper: Invoked by recovery-io via sudo.
# Validates args, then executes Codex as recovery-exec.
#
# Authentication: Codex uses browser OAuth; token is in ~/.codex/ (no API key).
# sudo -H ensures HOME=/home/recovery-exec so Codex finds its token and config.
#
# Security:
#   - This file: mode 0500 owned by recovery-exec (recovery-io cannot read)
#   - Only "exec" subcommand is accepted (prevents info leakage via other subcommands)
set -euo pipefail

if [[ "${1:-}" != "exec" ]]; then
    echo "denied: only 'exec' subcommand is permitted" >&2
    exit 1
fi

exec "{{ recovery_exec_codex_bin }}" "$@"
