#!/bin/bash
# recovery-investigate-dispatch.sh — deployed on {{ target_item.name }}
# Called via SSH forced command from recovery-exec@{{ inventory_hostname }}.
# Validates SSH_ORIGINAL_COMMAND against an allowlist, then executes it.
# No arguments accepted from the SSH client beyond the forced command key.
set -euo pipefail

cmd="${SSH_ORIGINAL_COMMAND:-status}"

case "$cmd" in
  # --- Service checks (systemctl status / journalctl) ---
{% for svc in target_item.investigate_services %}
  {{ svc }})
    systemctl status {{ svc }} --no-pager -l
    ;;
  journal-{{ svc }})
    journalctl -u {{ svc }} -n 100 --no-pager
    ;;
{% endfor %}
  status)
{% for svc in target_item.investigate_services %}
    echo "=== {{ svc }} ==="
    systemctl status {{ svc }} --no-pager -l || true
{% endfor %}
    ;;

  # --- Common system checks ---
  failed)
    systemctl --failed --no-pager
    ;;
  disk)
    df -h
    ;;
  memory)
    free -h
    echo "--- OOM (last 20 kernel messages) ---"
    journalctl -k -n 20 --no-pager | grep -i 'oom\|out of memory' || echo 'no OOM entries'
    ;;
  load)
    uptime
    ;;
  network)
    ip addr
    echo "---"
    ip route
    echo "---"
    resolvectl status 2>/dev/null || cat /etc/resolv.conf
    ;;
  ports)
    ss -ltnup
    ;;
  journal-system)
    journalctl -p warning..err -n 50 --no-pager
    ;;

  # --- Node-specific checks ---
{% for extra in target_item.investigate_extra | default([]) %}
  {{ extra.name }})
    {{ extra.cmd }}
    ;;
{% endfor %}

  *)
    echo "denied: unknown command '${cmd}'" >&2
    exit 1
    ;;
esac
