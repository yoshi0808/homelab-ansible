#!/bin/bash
# homelab-investigate-{{ target.name }}: SSH investigation wrapper for {{ target.name }}.
# Called by Codex: homelab-investigate-{{ target.name }} <check>
# Hostname is hardcoded (§4.3: connection target fixed in script, not from args).
# -F /dev/null: skip system ssh_config (bwrap UID mapping breaks ownership checks).
set -euo pipefail

KEY=/home/recovery-exec/.ssh/id_recovery_investigate
KNOWN=/home/recovery-exec/.ssh/known_hosts

# Allowlist mirrors the dispatch script on {{ target.name }}.
case "${1:-status}" in
  {% for svc in target.investigate_services %}{{ svc }}|journal-{{ svc }}|{% endfor %}failed|disk|memory|load|network|ports|journal-system|status{% for extra in target.investigate_extra | default([]) %}|{{ extra.name }}{% endfor %})
    exec ssh -T \
        -F /dev/null \
        -i "$KEY" \
        -o StrictHostKeyChecking=yes \
        -o UserKnownHostsFile="$KNOWN" \
        -o ConnectTimeout=10 \
        -o BatchMode=yes \
        "recovery-exec@{{ target.host }}" "${1:-status}"
    ;;
  *)
    echo "denied: unknown check '${1:-}'" >&2
    exit 1
    ;;
esac
