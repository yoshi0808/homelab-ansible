model = "{{ recovery_exec_codex_model }}"
approval_policy = "never"

# Sandbox: allow network (for SSH wrappers to reach targets).
# /var/lib/recovery-exec is in ReadWritePaths so bwrap can bind-mount it writable.
[sandbox_workspace_write]
network_access = true

# Execpolicy: deny all by default; allow only homelab-* wrapper scripts (§5.3).
[execpolicy]
default_policy = "deny"

{% for target in recovery_exec_targets %}
[[execpolicy.rules]]
command = "homelab-investigate-{{ target.name }}"
policy = "allow"

[[execpolicy.rules]]
command = "homelab-recover-{{ target.name }}"
policy = "allow"

{% endfor %}
