#!/usr/bin/env python3
"""
Homelab Recovery Slack Listener — agentic loop (§6.3).

Python owns all side-effects (SSH / ping / recovery trigger).
Claude receives available actions + history in each prompt and returns
one JSON object per turn. Claude never executes Bash / Write / Edit.
"""

import json
import logging
import os
import re
import subprocess
import sys

from slack_bolt import App
from slack_bolt.adapter.socket_mode import SocketModeHandler

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(message)s",
    stream=sys.stdout,
)
log = logging.getLogger("recovery-slack-listener")

BOT_TOKEN          = os.environ["SLACK_BOT_TOKEN"]
APP_TOKEN          = os.environ["SLACK_APP_TOKEN"]
AUTHORIZED_USER_ID = os.environ["SLACK_AUTHORIZED_USER_ID"]
QUORY_HOST         = os.environ.get("RECOVERY_QUORY_HOST", "{{ recovery_slack_quory_host }}")
CLAUDE_PATH        = "{{ recovery_slack_claude_path }}"
CLAUDE_WS          = "{{ recovery_slack_claude_ws }}"
MAX_TURNS          = {{ recovery_slack_max_turns }}
KEY_DIR            = "{{ recovery_slack_listener_key_dir }}"
STATUS_USER        = "{{ recovery_slack_status_user }}"
TRIGGER_USER       = "{{ recovery_slack_trigger_user }}"
SSH_TIMEOUT        = 15

_STATUS_CFG  = {{ recovery_slack_status_targets | to_json }}
_STATUS_HOST = {c["name"]: c["host"] for c in _STATUS_CFG}
_STATUS_KEY  = {
    c["name"]: f"{KEY_DIR}/id_status_ansy_{c['name'].replace('-', '_')}"
    for c in _STATUS_CFG
}
_TRIGGER_KEY = {
    t: f"{KEY_DIR}/id_trigger_ansy_{t.replace('-', '_')}"
    for t in {{ recovery_slack_targets | to_json }}
}


# ---------------------------------------------------------------------------
# Action implementations — Python executes; Claude never touches these
# ---------------------------------------------------------------------------

def _ssh_status(target: str) -> dict:
    r = subprocess.run(
        ["ssh", "-T",
         "-i", _STATUS_KEY[target],
         "-o", "StrictHostKeyChecking=yes",
         "-o", "BatchMode=yes",
         "-o", f"ConnectTimeout={SSH_TIMEOUT}",
         f"{STATUS_USER}@{_STATUS_HOST[target]}"],
        capture_output=True, text=True, timeout=SSH_TIMEOUT + 5,
    )
    log.info("ssh_status target=%s rc=%d", target, r.returncode)
    if r.returncode != 0:
        return {"ok": False, "error": r.stderr[:300] or f"rc={r.returncode}"}
    try:
        return {"ok": True, "data": json.loads(r.stdout)}
    except json.JSONDecodeError:
        return {"ok": False, "error": f"invalid JSON: {r.stdout[:200]}"}


def _ping(host: str) -> dict:
    r = subprocess.run(["ping", "-c", "1", "-W", "3", host], capture_output=True)
    return {"ok": True, "reachable": r.returncode == 0}


def _trigger(target: str) -> dict:
    r = subprocess.run(
        ["ssh",
         "-i", _TRIGGER_KEY[target],
         "-o", "StrictHostKeyChecking=yes",
         "-o", "BatchMode=yes",
         "-o", f"ConnectTimeout={SSH_TIMEOUT}",
         f"{TRIGGER_USER}@{QUORY_HOST}"],
        capture_output=True, timeout=SSH_TIMEOUT + 5,
    )
    log.info("trigger target=%s rc=%d", target, r.returncode)
    return {"ok": r.returncode == 0}


# Fixed action registry — claude may only request actions listed here
ACTIONS: dict = {
    "authy_healthcheck":          lambda: _ssh_status("authy"),
    "monnie_healthcheck":         lambda: _ssh_status("monnie"),
    "network_probe_authy":        lambda: _ping(_STATUS_HOST["authy"]),
    "network_probe_monnie":       lambda: _ping(_STATUS_HOST["monnie"]),
    "network_probe_sophos_fw":    lambda: _ping("{{ recovery_slack_sophos_host }}"),
    "trigger_recovery_authy":     lambda: _trigger("authy"),
    "trigger_recovery_monnie":    lambda: _trigger("monnie"),
    "trigger_recovery_sophos_fw": lambda: _trigger("sophos-fw"),
}
_TRIGGER_ACTIONS = {k for k in ACTIONS if k.startswith("trigger_recovery_")}

# trigger 実行前に必須となる調査アクションの対応表
_TRIGGER_PREREQ: dict[str, str] = {
    "trigger_recovery_authy":     "authy_healthcheck",
    "trigger_recovery_monnie":    "monnie_healthcheck",
    "trigger_recovery_sophos_fw": "network_probe_sophos_fw",
}


def _is_unhealthy(check_action: str, result: dict) -> bool:
    """調査結果がサービス異常を確認できている場合のみ True を返す。
    SSH/ping 失敗（tool error）は不確かなため False 扱い。"""
    if not result.get("ok"):
        return False  # 接続失敗 → 異常の確証なし
    data = result.get("data", {})
    if check_action == "authy_healthcheck":
        return data.get("freeradius", {}).get("service_active") != "active"
    if check_action == "monnie_healthcheck":
        svcs = data.get("services", {})
        return bool(svcs) and any(v != "active" for v in svcs.values())
    if check_action == "network_probe_sophos_fw":
        return not result.get("reachable", True)
    return False

_SYSTEM = """\
あなたは homelab の復旧・調査 AI です。

## ルール（厳守）
- 出力は JSON オブジェクト 1 個だけ。コードブロック・説明文・前置きは一切不要
- 調査継続: {"action": "<action_name>"}
- 調査完了（対応不要）: {"action": "done", "message": "<ユーザーへの日本語返答>"}
- 同じアクションを 2 回実行しないこと

## 利用可能なアクション
### 調査系
- authy_healthcheck       : authy の FreeRADIUS 状態を取得（JSON）
- monnie_healthcheck      : monnie の監視スタック状態を取得（JSON）
- network_probe_authy     : authy への ping（到達確認）
- network_probe_monnie    : monnie への ping（到達確認）
- network_probe_sophos_fw : sophos-fw への ping（到達確認）

### 復旧系（調査で必要と判断した場合のみ）
- trigger_recovery_authy      : authy 復旧パイプライン起動（不可逆）
- trigger_recovery_monnie     : monnie 復旧パイプライン起動（不可逆）
- trigger_recovery_sophos_fw  : sophos-fw 復旧パイプライン起動（不可逆）

### 終了
- done : 調査完了。message フィールドに Slack 向け日本語返答を必ず入れること

## 管理対象
- authy       : FreeRADIUS (freeradius.service)
- monnie      : prometheus / grafana-server / loki / unpoller
- sophos-fw   : Sophos ファイアウォール
"""


# ---------------------------------------------------------------------------
# Claude interaction
# ---------------------------------------------------------------------------

def _extract_json(text: str) -> dict:
    text = text.strip()
    text = re.sub(r'^```(?:json)?\n?', '', text)
    text = re.sub(r'\n?```$', '', text)
    text = text.strip()
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass
    start, end = text.find('{'), text.rfind('}')
    if start != -1 and end != -1:
        return json.loads(text[start:end + 1])
    raise ValueError(f"JSON not found in: {text[:200]}")


def _ask_claude(prompt: str) -> dict:
    r = subprocess.run(
        [CLAUDE_PATH, "-p", prompt,
         "--setting-sources", "project",
         "--permission-mode", "dontAsk"],
        capture_output=True, text=True,
        cwd=CLAUDE_WS, timeout=90,
    )
    if r.returncode != 0:
        raise RuntimeError(f"claude rc={r.returncode}: {r.stderr[:200]}")
    return _extract_json(r.stdout)


def run_loop(user_request: str) -> str:
    history: list[dict] = []

    for turn in range(MAX_TURNS):
        history_section = ""
        if history:
            history_section = "\n## これまでの調査結果\n"
            for h in history:
                history_section += (
                    f"\n### {h['action']}\n"
                    f"```json\n{json.dumps(h['result'], ensure_ascii=False, indent=2)}\n```\n"
                )

        prompt = (
            _SYSTEM
            + history_section
            + f"\n## ユーザーの要求\n{user_request}\n\n次のアクション（JSON のみ）:"
        )

        log.info("loop turn=%d/%d prompt_chars=%d", turn + 1, MAX_TURNS, len(prompt))

        try:
            decision = _ask_claude(prompt)
        except (ValueError, RuntimeError, subprocess.TimeoutExpired) as exc:
            log.error("claude error on turn %d: %s", turn + 1, exc)
            return f"Claude との通信でエラーが発生しました: {exc}"

        action = decision.get("action", "done")
        log.info("claude action=%s", action)

        if action == "done":
            return decision.get("message", "(返答なし)")

        if action not in ACTIONS:
            log.error("unknown action: %s", action)
            return f"不明なアクション '{action}' が返されました。"

        # 同一アクションの重複実行を Python 側で機械的に拒否
        if any(h["action"] == action for h in history):
            log.warning("duplicate action rejected: %s already in history", action)
            history.append({"action": action, "result": {
                "ok": False,
                "error": f"Python拒否: {action} は既に実行済み（同一ループ内での重複実行は不可）",
            }})
            continue

        # trigger 実行前の Python 側検証
        if action in _TRIGGER_ACTIONS:
            prereq = _TRIGGER_PREREQ[action]
            prereq_hist = next((h for h in history if h["action"] == prereq), None)
            if prereq_hist is None:
                log.warning("trigger %s rejected: %s not in history", action, prereq)
                history.append({"action": action, "result": {
                    "ok": False,
                    "error": f"Python拒否: {prereq} が未実行のため trigger 不可",
                }})
                continue
            if not _is_unhealthy(prereq, prereq_hist["result"]):
                log.warning("trigger %s rejected: %s showed no confirmed failure", action, prereq)
                history.append({"action": action, "result": {
                    "ok": False,
                    "error": f"Python拒否: {prereq} で異常が確認できていないため trigger 不可",
                }})
                continue

        try:
            result = ACTIONS[action]()
        except subprocess.TimeoutExpired:
            result = {"ok": False, "error": "timeout"}
        except Exception as exc:
            result = {"ok": False, "error": str(exc)}

        log.info("action=%s ok=%s", action, result.get("ok"))
        history.append({"action": action, "result": result})

        if action in _TRIGGER_ACTIONS:
            target = action.replace("trigger_recovery_", "").replace("_", "-")
            if result.get("ok"):
                return f"`{target}` の復旧パイプラインを起動しました。Slack に進捗が通知されます。"
            return f"`{target}` へのトリガー送信に失敗しました。quory の状態を確認してください。"

    return "最大調査ターン数に達しました。最後の調査結果を基に手動で判断してください。"


# ---------------------------------------------------------------------------
# Slack event handler
# ---------------------------------------------------------------------------

app = App(token=BOT_TOKEN)


@app.event("app_mention")
def handle_mention(event, say):
    user_id = event.get("user", "")
    text    = event.get("text", "")

    if user_id != AUTHORIZED_USER_ID:
        log.warning("Unauthorized mention from user_id=%s — ignored", user_id)
        return

    clean = re.sub(r"<@[A-Z0-9]+>", "", text).strip()
    log.info("Mention: %s", clean)
    say(f"<@{user_id}> 調査を開始します...")

    try:
        answer = run_loop(clean)
    except Exception as exc:
        log.exception("run_loop error")
        answer = f"予期しないエラーが発生しました: {exc}"

    say(f"<@{user_id}>\n{answer[:3800]}")


if __name__ == "__main__":
    log.info("Starting recovery Slack listener (authorized_user=%s)", AUTHORIZED_USER_ID)
    SocketModeHandler(app, APP_TOKEN).start()
