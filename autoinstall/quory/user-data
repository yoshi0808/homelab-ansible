#cloud-config
autoinstall:
  version: 1
  refresh-installer:
    update: false

  locale: ja_JP.UTF-8
  keyboard:
    layout: jp
  timezone: Asia/Tokyo

  source:
    id: ubuntu-server
    search_drivers: false

  network:
    version: 2
    ethernets:
      all-en:
        match:
          name: "en*"
        dhcp4: true
        dhcp6: false
      all-eth:
        match:
          name: "eth*"
        dhcp4: true
        dhcp6: false

  storage:
    layout:
      name: direct
      match:
        size: largest

  ssh:
    install-server: true
    allow-pw: false

  packages:
    - openssh-server
    - qemu-guest-agent
    - curl
    - wget
    - git
    - vim
    - unattended-upgrades

  updates: security
  shutdown: reboot

  user-data:
    hostname: quory
    fqdn: quory.internal
    manage_etc_hosts: true
    users:
      - name: yoshi
        gecos: Yoshi
        groups:
          - adm
          - sudo
        shell: /bin/bash
        lock_passwd: true
        sudo: "ALL=(ALL) NOPASSWD:ALL"
        ssh_authorized_keys:
          - ssh-rsa  cardno:14 700 491
          - ssh-rsa  yoshi@yoshi-pc

  late-commands:
    - curtin in-target -- systemctl enable ssh
    - curtin in-target -- systemctl enable qemu-guest-agent
    - curtin in-target -- systemctl enable unattended-upgrades
    - curtin in-target -- dpkg-reconfigure -f noninteractive unattended-upgrades
    - curtin in-target -- mkdir -p /etc/ssh/sshd_config.d
    - |
      cat > /target/etc/ssh/sshd_config.d/99-quory-hardening.conf <<'EOF'
      PasswordAuthentication no
      KbdInteractiveAuthentication no
      ChallengeResponseAuthentication no
      PermitRootLogin no
      PubkeyAuthentication yes
      EOF
    - |
      cat > /target/etc/apt/apt.conf.d/20auto-upgrades <<'EOF'
      APT::Periodic::Update-Package-Lists "1";
      APT::Periodic::Unattended-Upgrade "1";
      EOF
    - |
      cat > /target/etc/apt/apt.conf.d/52unattended-upgrades-local <<'EOF'
      Unattended-Upgrade::Automatic-Reboot "false";
      EOF
